{
  "name": "boardboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "preview:stop": "node scripts/stop-preview.mjs",
    "cf:build": "node scripts/stop-preview.mjs && opennextjs-cloudflare build",
    "preview": "node scripts/stop-preview.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview -- -c wrangler.toml -c wrangler.do.toml",
    "deploy": "node scripts/stop-preview.mjs && opennextjs-cloudflare build && wrangler d1 migrations apply boardboard-db --remote && wrangler deploy -c wrangler.do.toml && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@opennextjs/cloudflare": "^1.3.1",
    "drizzle-orm": "^0.44.1",
    "fractional-indexing": "^3.2.0",
    "konva": "^9.3.22",
    "next": "^15.3.2",
    "next-auth": "^5.0.0-beta.28",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.2.4",
    "zod": "^3.24.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250521.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "wrangler": "^4.16.0"
  }
}
